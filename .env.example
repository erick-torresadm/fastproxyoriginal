# ===========================================
# CONFIGURAÇÃO STRIPE - MODO TESTE
# ===========================================
# Para testar sem pagar dinheiro real:
# 1. Pegue suas chaves de teste em: https://dashboard.stripe.com/test/apikeys
# 2. Substitua as chaves abaixo pelas de TESTE (sk_test_...)
# 3. No Vercel, configure as variáveis de ambiente

# ===========================================
# MODO: TROQUE PARA 'false' QUANDO FOR PRODUÇÃO
# ===========================================
STRIPE_TEST_MODE=true

# ===========================================
# CHAVES DE TESTE DO STRIPE
# Obtidas em: https://dashboard.stripe.com/test/apikeys
# ===========================================
STRIPE_SECRET_KEY=sk_test_51...SUA_CHAVE_AQUI
STRIPE_PUBLISHABLE_KEY=pk_test_51...SUA_CHAVE_AQUI
STRIPE_WEBHOOK_SECRET_TEST=whsec_...SEU_WEBHOOK_AQUI

# ===========================================
# CHAVES DE PRODUÇÃO (descomente quando for subir)
# ===========================================
# STRIPE_SECRET_KEY=sk_live_51...SUA_CHAVE_AQUI
# STRIPE_PUBLISHABLE_KEY=pk_live_51...SUA_CHAVE_AQUI
# STRIPE_WEBHOOK_SECRET=whsec_...SEU_WEBHOOK_AQUI

# ===========================================
# OUTRAS CONFIGURAÇÕES
# ===========================================
PORT=3000
MONGODB_URI=sua_url_mongodb_aqui
JWT_SECRET=fastproxy_secret_key_2024
JWT_EXPIRE=7d
APP_URL=http://localhost:3000

# ===========================================
# PROXY CONFIG
# ===========================================
PROXY_IP=177.54.146.90
PROXY_PORT_START=11331
PROXY_PORT_END=11368
