{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/test", "dest": "server.js" },
    { "src": "/debug/(.*)", "dest": "server.js" },
    { "src": "/success.html", "dest": "public/success.html" },
    { "src": "/cancel.html", "dest": "public/cancel.html" },
    { "src": "/portal.html", "dest": "public/portal.html" },
    { "src": "/admin.html", "dest": "public/admin.html" },
    { "src": "/(.*)", "dest": "public/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}